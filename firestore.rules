rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles: owner-only access
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progress records: user owns their own progress
    // Check resource.data.userId instead of parsing doc ID
    match /progress/{progressId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // Curriculum: public read, no client-side writes
    match /curriculum/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // High scores: user can read/write their own, only higher scores allowed
    match /highScores/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (resource == null || request.resource.data.score > resource.data.score);
    }
  }
}